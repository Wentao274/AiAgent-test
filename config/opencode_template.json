{
  "$schema": "https://opencode.ai/config.json",
  "_comment": "THIS IS A REFERENCE TEMPLATE ONLY. The Jenkinsfile dynamically generates opencode.json at runtime with actual MODEL, BASE_URL, API_KEY values.",
  "provider": {
    "custom-openai": {
      "options": {
        "baseURL": "{env:BASE_URL}/v1",
        "apiKey": "{env:API_KEY}"
      },
      "models": {
        "kimi-k2.5": {
          "name": "kimi-k2.5"
        }
      }
    }
  },
  "model": "custom-openai/kimi-k2.5",
  "autoupdate": false,
  "tools": {
    "webfetch": true,
    "websearch": true
  }
}
